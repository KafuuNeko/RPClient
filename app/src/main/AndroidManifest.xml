<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".RPClientApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RPClient">
        <activity
            android:name=".feature.characteredit.CharacterEditActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.llmprovideredit.LLMProviderEditActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.llmproviderlist.LLMProviderListActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.worldbookedit.WorldBookEditActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.worldbookentryedit.WorldBookEntryEditActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.worldbooklist.WorldBookListActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.chat.ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.chatcreate.ChatCreateActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.characterlist.CharacterListActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.promptpreset.PromptPresetActivity"
            android:exported="false"
            android:theme="@style/Theme.RPClient" />
        <activity
            android:name=".feature.main.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RPClient">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
